<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Zonest Engine - Oficial</title>
    
    <style>
        :root {
            --bg: #f5f7fa;
            --surface: #ffffff;
            --accent: #007bff;
            --warning: #f39c12;
            --text-main: #333333;
            --text-dim: #888888;
            --border: #e1e8ed;
            --shadow: 0 10px 30px rgba(0,0,0,0.05);
            --btn-bg: #ffffff;
        }

        body.dark-mode {
            --bg: #0d1117;
            --surface: #161b22;
            --text-main: #f0f6fc;
            --text-dim: #8b949e;
            --border: #30363d;
            --shadow: 0 10px 30px rgba(0,0,0,0.3);
            --btn-bg: #21262d;
        }

        body {
            background-color: var(--bg);
            color: var(--text-main);
            font-family: -apple-system, system-ui, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            transition: background 0.3s ease;
            user-select: none;
            -webkit-user-select: none;
        }

        .ads-branding-zone {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 10px;
        }

        .top-ads {
            width: 100%;
            max-width: 400px;
            height: 60px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .dev-credit {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--accent);
            margin-top: 8px;
            padding: 5px 18px;
            background: rgba(0, 123, 255, 0.1);
            border-radius: 20px;
            border: 1px solid rgba(0, 123, 255, 0.2);
        }

        .header-bar {
            width: 100%;
            max-width: 400px;
            display: flex;
            justify-content: flex-end;
            padding: 10px 20px;
            box-sizing: border-box;
        }

        #theme-toggle {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-main);
            padding: 8px;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: var(--shadow);
        }

        .container {
            width: 90%;
            max-width: 360px;
            background: var(--surface);
            padding: 25px;
            border-radius: 25px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
        }

        #display {
            width: 100%;
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--text-main);
            font-size: 2.5rem;
            text-align: right;
            padding: 20px;
            box-sizing: border-box;
            border-radius: 15px;
            margin-bottom: 20px;
            outline: none;
        }

        .keypad {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        button {
            height: 62px;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: var(--btn-bg);
            color: var(--text-main);
            font-size: 1.3rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.1s ease;
        }

        button:active { transform: scale(0.95); opacity: 0.8; }
        .op { color: var(--accent); }
        .eq { background: var(--accent); color: #ffffff; grid-column: span 2; border: none; }
        .clear { color: #dc3545; }

        .preview-area {
            margin-top: 25px;
            background: var(--bg);
            padding: 20px;
            border-radius: 15px;
            border: 1px solid var(--border);
            min-height: 130px;
        }

        .preview-label {
            font-size: 10px;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
            margin-bottom: 10px;
            text-align: center;
        }

        #canvas-output {
            font-family: 'Courier New', monospace;
            white-space: pre;
            text-align: right;
            color: var(--text-main);
            font-size: 1.3rem;
            line-height: 1.2;
        }

        footer {
            margin-top: auto;
            padding: 25px;
            text-align: center;
            width: 100%;
            max-width: 400px;
        }

        .copyright-text {
            font-size: 10px;
            color: var(--text-dim);
            font-weight: 600;
        }

        .legal-warning {
            color: #dc3545;
            font-size: 11px;
            font-weight: 700;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="ads-branding-zone">
        <div class="top-ads">
            <span style="color: var(--text-dim); font-size: 9px; opacity: 0.5;">ZONEST SECURE ADS</span>
        </div>
        <div class="dev-credit">By Derick Gabriel | Zonest Labs</div>
    </div>

    <div class="header-bar">
        <button id="theme-toggle" onclick="_theme_toggle()">🌙</button>
    </div>

    <div class="container">
        <input type="text" id="display" placeholder="0" readonly>
        <div class="keypad" id="btn-grid"></div>
        <div class="preview-area">
            <div id="label-status" class="preview-label">...</div>
            <div id="canvas-output">SISTEMA IDLE</div>
        </div>
    </div>

    <footer>
        <div class="copyright-text">© 2026 Zonest Labs | Todos os direitos reservados.</div>
        <div class="legal-warning">⚠️ PIRATARIA É CRIME. NÃO ROUBE MEU PROJETO. ⚠️</div>
    </footer>

    <script>
        /* ZONEST ENGINE - DEFESA ATIVA */
        document.addEventListener('contextmenu', e => e.preventDefault());
        document.onkeydown = e => {
            if(e.keyCode == 123 || (e.ctrlKey && e.shiftKey && (e.keyCode == 73 || e.keyCode == 74)) || (e.ctrlKey && e.keyCode == 85)) 
            return false;
        };

        const _isPT = navigator.language.startsWith('pt');
        const ui = { 
            check: _isPT ? "VERIFICANDO " : "VERIFYING ", 
            ready: _isPT ? "ZONEST PRONTO" : "ZONEST READY", 
            done: _isPT ? "CONTA ARMADA:" : "RESULT:" 
        };

        const _keys = [
            {v:'C', t:'clear', f:'reset'}, {v:'DEL', t:'', f:'del'}, {v:'÷', t:'op', f:'setOp', o:'/'}, {v:'×', t:'op', f:'setOp', o:'*'},
            {v:'7', f:'add'}, {v:'8', f:'add'}, {v:'9', f:'add'}, {v:'-', t:'op', f:'setOp', o:'-'},
            {v:'4', f:'add'}, {v:'5', f:'add'}, {v:'6', f:'add'}, {v:'+', t:'op', f:'setOp', o:'+'},
            {v:'1', f:'add'}, {v:'2', f:'add'}, {v:'3', f:'add'}, {v:'0', f:'add'},
            {v:'.', f:'add'}, {v:'=', t:'eq', f:'run'}
        ];

        const grid = document.getElementById('btn-grid');
        _keys.forEach(k => {
            let b = document.createElement('button');
            b.innerText = k.v;
            if(k.t) b.className = k.t;
            b.onclick = () => engine[k.f](k.o || k.v);
            grid.appendChild(b);
        });

        const display = document.getElementById('display'), output = document.getElementById('canvas-output'), statusLabel = document.getElementById('label-status');

        const engine = {
            a: '', b: '', o: null, lock: false,
            add(v) { if(this.lock) this.reset(); if(!this.o) { this.a += v; display.value = this.a; } else { this.b += v; display.value = this.a + this.o + this.b; } },
            setOp(op) { if(!this.a) return; this.o = op; this.lock = false; display.value = this.a + " " + op; },
            reset() { this.a = ''; this.b = ''; this.o = null; this.lock = false; display.value = ''; output.innerText = 'READY'; statusLabel.innerText = ui.ready; output.style.color = "var(--text-main)"; },
            del() { if(this.b) this.b = this.b.slice(0, -1); else if(this.o) this.o = null; else this.a = this.a.slice(0, -1); display.value = this.a + (this.o || '') + this.b; },
            async run() {
                if(!this.a || !this.b) return; this.lock = true;
                let n1 = parseFloat(this.a), n2 = parseFloat(this.b), res = 0;
                
                for(let i=1; i<=4; i++) {
                    output.style.color = "var(--warning)";
                    output.innerText = ui.check + i + "/4...\n[ZONEST ANALYTICS]";
                    await new Promise(r => setTimeout(r, 1250));
                }

                if(this.o === '+') res = n1 + n2; if(this.o === '-') res = n1 - n2;
                if(this.o === '*') res = n1 * n2; if(this.o === '/') res = n1 / n2;

                display.value = res; statusLabel.innerText = ui.done; output.style.color = "var(--text-main)";
                let s1 = n1.toString(), s2 = n2.toString(), sr = res.toString(), max = Math.max(s1.length, s2.length + 1, sr.length);
                output.innerText = s1.padStart(max) + "\n" + this.o + s2.padStart(max-1) + "\n" + "-".repeat(max) + "\n" + sr.padStart(max);
                this.a = res.toString(); this.b = ''; this.o = null;
            }
        };

        function _theme_toggle() {
            document.body.classList.toggle('dark-mode');
            const isDark = document.body.classList.contains('dark-mode');
            document.getElementById('theme-toggle').innerText = isDark ? '☀️' : '🌙';
            localStorage.setItem('zonest-theme', isDark ? 'dark' : 'light');
        }

        if(localStorage.getItem('zonest-theme') === 'dark') {
            document.body.classList.add('dark-mode');
            document.getElementById('theme-toggle').innerText = '☀️';
        }
        statusLabel.innerText = ui.ready;
    </script>
</body>
</html>
